{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "pytest - All Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-k", "working", "--tb=short", "--headed"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "HEADLESS": "false"
      }
    }
    
  ]
}
